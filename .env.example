# Google Sheets -aikataulun julkaistun CSV:n URL.
# Sheetissä tulee olla sarakkeet: Päivä, Aika alkaa, Aika loppuu, Laji, Ohjaaja, Sali.
# Julkaise sheet: Tiedosto → Jaa → Julkaise verkkoon → Linkki → CSV → koko dokumentti.
# Jos muuttuja puuttuu, sivu näyttää content/schedule-fallback.json -tiedoston.
NEXT_PUBLIC_SCHEDULE_CSV_URL=

# Hakukoneindeksointi. Aseta arvoksi "true" vasta kun sivut viedään tuotantoon
# omalle domainille. Vercelin testi-URL:eissä jätä asettamatta tai "false",
# jolloin robots.txt blokkaa hakukoneet ja sivu lähettää noindex-metan.
NEXT_PUBLIC_ALLOW_INDEX=false
